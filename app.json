{
  "expo": {
    "name": "Esportes da Sorte",
    "slug": "EDScript",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#023697",
    "ios": {
      "backgroundColor": "#023697",
      "supportsTablet": true,
      "bundleIdentifier": "com.brcneto.edscript",
      "appleTeamId": "9HZC728P5D"
    },
    "android": {
      "backgroundColor": "#023697",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#023697"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.brcneto.edscript"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "69bc9be9-04b9-4b6c-94db-e4db2bec307f"
      }
    },
    "owner": "brcneto",
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-image",
      "./plugins/native-splash-plugin",
      "./plugins/android-build-config",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#023697"
        }
      ]
    ]
  }
}
