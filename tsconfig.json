{
	"extends": "expo/tsconfig.base",

	"compilerOptions": {
		"types": ["react-native"],
		"baseUrl": "./",
		"strict": true,
		"ignoreDeprecations": "6.0",
		"paths": {
			"@/*": ["./src/*"],
			"@assets/*": ["./assets/*"],
			"@components/*": ["./src/components/*"],
			"@config/*": ["./src/config/*"],
			"@hooks/*": ["./src/hooks/*"],
			"@routes/*": ["./src/routes/*"],
			"@screens/*": ["./src/screens/*"],
			"@styles/*": ["./src/styles/*"],
			"@utils/*": ["./src/utils/*"]
		}
	},
	"exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx"],
	"include": ["src/**/*", "src/types/**/*", "stampd-types.d.ts"]
}
